{
  "name": "@cyflow/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cyflow Prisma schema, client, and persistence repositories.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "validate": "prisma validate",
    "migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "deploy": "dotenv -e ../../apps/api/.env -- prisma migrate deploy",
    "push": "dotenv -e ../../apps/api/.env -- prisma db push",
    "studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cyflow/shared": "0.0.0",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "typescript": "^5.6.3"
  }
}

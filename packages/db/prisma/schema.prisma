// Cyflow data model (ARCHITECTURE.md §3). Postgres + Prisma.
// Phase 3 introduces persistence for the bundle engine: scenarios (with their
// blueprint), executions, and per-step bundle snapshots.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScenarioStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  scenarios    Scenario[]
  connections  Connection[]
}

model Scenario {
  id     String         @id @default(cuid())
  userId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  status ScenarioStatus @default(DRAFT)

  // Schedule config (Phase 3): { type: 'manual' } | { type: 'webhook' } |
  // { type: 'interval', minutes: number }.
  schedule Json?

  // The chain as JSON — the source of truth the engine runs. The `Module` rows
  // below mirror it row-per-node for querying/UI; the blueprint stays canonical.
  blueprint Json

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  modules    Module[]
  executions Execution[]
}

model Module {
  id         String   @id @default(cuid())
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  // Node id within the blueprint (e.g. "1", "2").
  nodeId    String
  app       String
  operation String
  kind      String
  params    Json

  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  // Linear `next` pointer (Router upgrades this in Phase 8).
  next     String?
  position Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([scenarioId, nodeId])
}

model Connection {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appKey String // "telegram", "http"
  name   String // user label

  // Encrypted at rest (Phase 7). Holds api keys / oauth tokens.
  encryptedData String

  createdAt DateTime @default(now())
  modules   Module[]
}

model Execution {
  id         String          @id @default(cuid())
  scenarioId String
  scenario   Scenario        @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  status     ExecutionStatus @default(RUNNING)

  // Total operations across the run (Make's billing unit).
  operations Int @default(0)

  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  steps ExecutionStep[]
}

model ExecutionStep {
  id          String    @id @default(cuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  // Which blueprint module this step corresponds to ("1", "2", ...).
  moduleNodeId String
  status       String // "success" | "error"
  operations   Int    @default(0)

  // Bundle-level snapshots for the "Run once" replay (Phase 6).
  input  Json? // input bundles this module received
  output Json? // output bundles this module produced

  error String?
  ms    Int    @default(0)
  order Int    @default(0)

  createdAt DateTime @default(now())

  @@index([executionId])
}

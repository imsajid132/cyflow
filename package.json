{
  "name": "cyflow",
  "private": true,
  "version": "0.0.0",
  "description": "Cyflow — self-hosted Make.com clone. Bundle-based automation engine.",
  "scripts": {
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:generate:pnpm": "pnpm --filter @cyflow/db generate",
    "build": "npm run db:generate",
    "hostinger:generate": "npm run db:generate",
    "hostinger:migrate": "prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "hostinger:build": "npm run build",
    "hostinger:start": "node hostinger.entry.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*",
    "apps/api",
    "apps/worker"
  ]
}

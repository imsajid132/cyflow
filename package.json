{
  "name": "cyflow-social",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cyflow Social — social media content generation, image generation, scheduling, and automated publishing for Facebook Pages, Instagram Professional, and Threads.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch",
    "scheduler:once": "node src/scheduler/runOnce.js",
    "worker": "node src/workers/worker.js",
    "worker:once": "node src/workers/runWorkerOnce.js",
    "staging:preflight": "node tools/staging-preflight.mjs",
    "staging:health": "node tools/staging-health.mjs",
    "staging:init-storage": "node tools/staging-init-storage.mjs",
    "migrate:status": "node tools/migration-status.mjs",
    "migrate:check": "node tools/migration-check.mjs",
    "test:integration": "node --import ./tests/integration/helpers/preload.js --test --test-concurrency=1 tests/integration/*.test.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.11.0",
    "node-cron": "^4.6.0",
    "node-html-parser": "^9.0.0",
    "openai": "^6.47.0",
    "p-limit": "^6.1.0",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}

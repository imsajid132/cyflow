# Copy to .env for local dev (docker-compose.yml provides these services).

# Postgres (Prisma)
DATABASE_URL="postgresql://cyflow:cyflow@localhost:5432/cyflow?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Connection vault — AES-256-GCM key for encrypting stored credentials.
# Any string; it's hashed to 32 bytes. Use a strong random value in production.
CYFLOW_ENCRYPTION_KEY="dev-only-change-me"

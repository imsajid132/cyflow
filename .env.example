# Cyflow Social — environment template
#
# Copy to `.env` and fill in. NEVER commit a filled-in copy.
#
# Every credential slot below is deliberately blank. A value committed here
# becomes a value in everyone's shell history and in the Git object store, where
# deleting the line does not remove it.
#
# Staging and production requirements are called out inline. The two settings
# most often missed are ENABLE_LIVE_PROVIDER_PUBLISHING (whether real posts are
# sent to real business pages) and the two storage paths (whether uploads and
# exports survive a redeploy).

# --- Application -------------------------------------------------------------
NODE_ENV=development
PORT=3000
# The exact public origin. Staging and production MUST be https: secure session
# cookies are dropped over plain http, so users silently fail to stay signed in.
PUBLIC_BASE_URL=http://localhost:3000

# --- Database ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10

# --- Sessions and encryption -------------------------------------------------
SESSION_SECRET=
SESSION_COOKIE_NAME=cyflow_social_session
SESSION_MAX_AGE_MS=604800000
BCRYPT_ROUNDS=12

# Base64, decoding to exactly 32 bytes (AES-256).
#
# CHANGING THIS AFTER DATA EXISTS MAKES EVERY STORED CREDENTIAL UNREADABLE.
# Per-user OpenAI keys, HCTI credentials and social access tokens are encrypted
# with it. Rotating it requires re-encrypting stored rows first; there is no
# recovery from rotating it in place.
ENCRYPTION_KEY_BASE64=

# --- Media storage -----------------------------------------------------------
# Uploaded and generated image bytes live on a private filesystem path, OUTSIDE
# the public app source, and are never web-served directly.
#
# The default is a temp directory so local dev and the test suite work with no
# configuration. A temp directory is WIPED ON REDEPLOY, so staging and
# production MUST set an absolute persistent path here or silently lose every
# uploaded image on the next deploy.
MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_PATH=
MAX_MEDIA_UPLOAD_BYTES=8388608

# --- Export storage ----------------------------------------------------------
# Where user data-export archives are written. Defaults to `<cwd>/.data/exports`,
# which is inside the deployment directory and does not survive a redeploy.
#
# Must be a DIFFERENT directory from MEDIA_STORAGE_PATH: export cleanup removes
# expired archives by sweeping its own root, and pointed at the media directory
# that sweep would delete users' images.
EXPORT_STORAGE_PATH=

# --- Durable worker ----------------------------------------------------------
# The worker is a SEPARATE persistent process (npm run worker). It claims jobs
# under a lease so two workers cannot run the same job; the lease must
# comfortably exceed the longest job, or a slow job is re-claimed while it is
# still running — which is how one scheduled post becomes two real posts.
WORKER_POLL_SECONDS=5
WORKER_LEASE_SECONDS=120
WORKER_CONCURRENCY=2
WORKER_HEARTBEAT_SECONDS=30
WORKER_MAX_ATTEMPTS=5
WORKER_BASE_RETRY_SECONDS=30
WORKER_MAX_RETRY_SECONDS=3600

# --- Scheduler ---------------------------------------------------------------
# Choose ONE scheduling mode. Host cron calling `npm run scheduler:once` is the
# documented default. Running host cron AND a persistent scheduler together will
# double-schedule every due job.
SCHEDULER_ENABLED=true
SCHEDULER_CRON=* * * * *
SCHEDULER_BATCH_SIZE=10
SCHEDULER_CONCURRENCY=3
SCHEDULER_LOCK_TIMEOUT_MINUTES=15
SCHEDULER_MAX_RETRIES=3
SCHEDULER_BASE_RETRY_MINUTES=5

# --- Provider publishing -----------------------------------------------------
# MUST START false. When false the app prepares and queues posts but makes NO
# call to Facebook, Instagram or Threads. Turn it on only for a deliberate,
# time-boxed test against a disposable account, then turn it off again.
#
# The failure mode of enabling this early is not an error message. It is a post
# on a real business's page.
ENABLE_LIVE_PROVIDER_PUBLISHING=false
PUBLISH_REQUEST_TIMEOUT_MS=20000
# Instagram publishes in two steps and Threads can lag, so a submitted post is
# re-checked after this delay rather than blindly retried, which would double-post.
PUBLISH_RECONCILE_DELAY_SECONDS=60
PUBLISH_MAX_RECONCILE_ATTEMPTS=5

# --- Automation --------------------------------------------------------------
AUTOMATION_REFILL_INTERVAL_HOURS=6

# --- Facebook Pages ----------------------------------------------------------
# Callback URIs must point at THIS environment's origin. A staging deployment
# reusing production callbacks will send users to production on sign-in.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=
META_REDIRECT_URI=

# --- Instagram Professional --------------------------------------------------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_GRAPH_API_VERSION=
INSTAGRAM_REDIRECT_URI=

# --- Threads -----------------------------------------------------------------
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_GRAPH_API_VERSION=
THREADS_REDIRECT_URI=

# --- OAuth -------------------------------------------------------------------
OAUTH_STATE_TTL_MINUTES=10
OAUTH_HTTP_TIMEOUT_MS=30000
OAUTH_TOKEN_REFRESH_LEEWAY_MINUTES=10

# --- OpenAI ------------------------------------------------------------------
# Each user supplies their own encrypted key in the app. These are fallbacks for
# local development only.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
# Optional. Planner generation and critic review use this when set; otherwise
# they fall back to OPENAI_TEXT_MODEL. Never exposed to users.
OPENAI_PLANNER_MODEL=
OPENAI_REQUEST_TIMEOUT_MS=45000
OPENAI_MAX_OUTPUT_TOKENS=1200

# --- HCTI (branded image rendering) ------------------------------------------
HCTI_API_BASE_URL=https://hcti.io/v1
HCTI_REQUEST_TIMEOUT_MS=45000
HCTI_MAX_IMAGE_BYTES=10485760

# --- Content limits ----------------------------------------------------------
MAX_POST_PROMPT_LENGTH=5000
MAX_CUSTOM_HTML_LENGTH=20000
MAX_CUSTOM_CSS_LENGTH=20000
MAX_DAILY_GENERATIONS_PER_USER=100

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info

# --- Legacy ------------------------------------------------------------------
# Each user supplies their own encrypted OpenAI key. Leave false; true restores
# a single global key for every user, which is not the intended model.
ALLOW_LEGACY_GLOBAL_OPENAI_KEY=false

# --- Managed single-process hosting ------------------------------------------
# For hosts that run exactly ONE process from `npm start`, with no cron and no
# way to keep a separate `npm run worker` alive (Hostinger managed Node among
# them). With this false, durable jobs on such a host never advance: posts stay
# queued, automations never refill, exports never build and deletions never
# complete, while the app looks perfectly healthy.
#
# When true, the web process also runs the scheduler tick and a bounded worker
# drain every 60 seconds. It drives the SAME services as the standalone
# scheduler and worker; no logic is duplicated. Leave false on any host that can
# run separate processes — a dedicated worker is better isolated.
HOSTINGER_SINGLE_PROCESS_JOBS=false

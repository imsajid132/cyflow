# apps/web — frontend build-time env (Vite inlines VITE_-prefixed vars).
# Copy to .env.local for local dev, or set in Vercel's Environment Variables.

# Base URL of the Cyflow API.
#   - "/"    -> SAME-ORIGIN: the API serves this app (single-domain Hostinger
#              deploy). The UI calls the API with relative paths — no separate
#              API host needed. This is what `npm run build:web` bakes in.
#   - <url>  -> a remote API, e.g. https://api.example.com (frontend hosted
#              separately, e.g. Vercel). Set it there as an env var.
#   - UNSET  -> local demo mode: the engine runs in the browser with mocked
#              HTTP/Telegram (no backend calls).
# VITE_CYFLOW_API_URL="/"
# For local dev against a local API, point it at the dev server instead:
# VITE_CYFLOW_API_URL="http://localhost:3001"

# Seed sample scenarios/connections/executions/data stores in local mode.
#   - UNSET/0 -> fresh, empty install (the default; what a real user sees).
#   - 1       -> populate the no-backend build with demo data for a showcase.
# Ignored when VITE_CYFLOW_API_URL is set (a real backend loads its own state).
# VITE_DEMO="1"

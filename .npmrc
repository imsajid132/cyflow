# Internal packages (@cyflow/*, engine, functions) are referenced by their exact
# local version "0.0.0" so BOTH npm and pnpm install this monorepo:
#   - npm resolves them via the "workspaces" field in the root package.json.
#     (npm rejects pnpm's "workspace:*" protocol, so we can't use it and stay
#     npm-compatible for Hostinger.)
#   - pnpm links them from the workspace instead of the registry. The exact
#     "0.0.0" pin also stops pnpm from picking the unrelated public "engine" /
#     "functions" packages, whose versions can't satisfy 0.0.0.
# npm ignores this unknown key; it only affects pnpm.
link-workspace-packages=true

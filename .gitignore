# Environment / secrets
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build output
dist/

# Local-only files
*.local

# Test coverage
coverage/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/

# Temp
tmp/
temp/

# Rendered creative review output (tests/helpers/renderPlan.mjs).
# Regenerated on demand; the cards are build artefacts, not source.
.render-review/

# Runtime data (local export archives, etc.)
.data/

# Screenshots the browser smokes drop in the working directory.
# Root-anchored on purpose: the tracked brand marks live under public/ and
# design-references/ and must keep being tracked. Without this, every smoke run
# leaves loose PNGs at the repo root, one `git add .` away from being committed.
/*.png
